ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxx
MASTER_PASSWORD=（任意のパスワードを設定）
HUGGING_FACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxx

# HuggingFace Pro契約時に true に変更するとFLUX.1-Kontext（構造保持img2img）を使用
